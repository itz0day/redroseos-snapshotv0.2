[Unit]
Description=RedRose OS Custom XFCE Session
After=systemd-user-sessions.service plymouth-quit-active.service
Conflicts=getty@tty1.service

[Service]
User=redrose
Group=redrose
WorkingDirectory=/home/redrose
PAMName=login
Environment=DISPLAY=:0
ExecStartPre=/usr/bin/xinit /usr/bin/true -- /usr/bin/X :0 -nolisten tcp -vt1
ExecStart=/usr/bin/startxfce4
Restart=always

[Install]
WantedBy=graphical.target
